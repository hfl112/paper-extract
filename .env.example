# 复制为 .env 并填入你自己的值

# Unpaywall / NCBI 礼貌请求用邮箱（建议填你自己的邮箱）
PAPER_EXTRACT_EMAIL=

# NCBI PubMed API Key（E-utilities 提速 3→10 req/s）：https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# 出版商全文 API（可选，取 OA 全文用）
SPRINGER_OA_API_KEY=
ELSEVIER_API_KEY=
WILEY_TDM_TOKEN=
CORE_API_KEY=

# LLM（search-plan --prompt / 别名扩展用；四选一或多填，走独立的 llmclient 包）
LLM_PROVIDER=
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
